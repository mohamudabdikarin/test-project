generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// COMPANY PROFILE
// ──────────────────────────────────────────────
model CompanyProfile {
  id    String  @id @default(uuid())
  name  String
  email String?
  phone String?

  // Relations
  users    User[]
  projects Project[]
  config   SystemConfig?

  @@map("company_profiles")
}

// ──────────────────────────────────────────────
// USER
// ──────────────────────────────────────────────
enum UserRole {
  ADMIN
  MANAGER
  MEMBER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String     @unique
  password_hash String
  role          UserRole   @default(MEMBER)
  status        UserStatus @default(ACTIVE)

  // Multi-company FK
  companyId String
  company   CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("users")
}

// ──────────────────────────────────────────────
// PROJECT — scoped to company
// ──────────────────────────────────────────────
enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id       String        @id @default(uuid())
  name     String
  location String?
  budget   Decimal?      @db.Decimal(12, 2)
  status   ProjectStatus @default(PLANNING)

  // Multi-company FK
  companyId String
  company   CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@map("projects")
}

// ──────────────────────────────────────────────
// SYSTEM CONFIG — Per-company settings (1:1)
// ──────────────────────────────────────────────
model SystemConfig {
  id                   String  @id @default(uuid())
  construction_enabled Boolean @default(true)

  // 1:1 with company
  companyId String         @unique
  company   CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("system_configs")
}
